# Copiar a .env en esta misma carpeta: cp .env.example .env

# --- PostgreSQL (debe coincidir con DATABASE_CONNECTION_URI) ---
POSTGRES_DATABASE=evolution_db
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=cambiar_esta_clave

# --- Evolution API (core) ---
SERVER_URL=http://127.0.0.1:8080
# Clave global (obligatoria en la práctica). Sin valor o línea vacía, Evolution usa la por defecto: BQYHJGJHJ
# (código: process.env.AUTHENTICATION_API_KEY || 'BQYHJGJHJ'). Si cambias esto, reinicia la API:
#   docker compose up -d api --force-recreate
# En peticiones HTTP el header debe ser exactamente: apikey: <tu_clave>  (no Authorization Bearer)
# Probar desde el host:
#   source .env && curl -s -X POST "http://127.0.0.1:8080/verify-creds" -H "apikey: $AUTHENTICATION_API_KEY" -H "Content-Type: application/json" -d '{}'
# Misma cadena en backend/.env como EVOLUTION_API_KEY si usas el webhook del RAG.
AUTHENTICATION_API_KEY=cambiar_misma_clave_que_BACKEND_EVOLUTION_API_KEY
# true = el webhook incluye en el JSON el token de la instancia (hash); el RAG lo valida contra Evolution.
# false = apikey en el webhook puede ir null y el backend devolverá 401 si EVOLUTION_VERIFY_WEBHOOK_APIKEY=true.
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
LANGUAGE=es

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:cambiar_esta_clave@evolution-postgres:5432/evolution_db?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_scanntech

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution

# Webhook al FastAPI en el host: usa host.docker.internal, NUNCA http://127.0.0.1:8000 (dentro del contenedor
# 127.0.0.1 es el propio contenedor → ECONNREFUSED).
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://host.docker.internal:8000/webhooks/evolution
# false = un solo POST a la URL de arriba. true añade /messages-upsert etc.; el RAG solo expone /webhooks/evolution.
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=false
WEBHOOK_EVENTS_SEND_MESSAGE=false
WEBHOOK_EVENTS_QRCODE_UPDATED=false
WEBHOOK_EVENTS_CONNECTION_UPDATE=true

# Menos ruido en logs (opcional)
LOG_LEVEL=ERROR,WARN,INFO,WEBHOOKS

# --- Manager (login) ---
# Con el perfil standalone-manager (:3001), nginx hace proxy de GET /, /verify-creds, /instance/*, etc. al
# contenedor "api"; solo /manager y /assets sirven el SPA. Así la URL por defecto http://127.0.0.1:3001
# funciona en el login sin cambiar el campo "Server URL".
# Si "Server URL" termina en /, el Manager llama GET ...//; nginx redirige 302 a .../ con el puerto correcto.
# Alternativa sin contenedor frontend: http://127.0.0.1:8080/manager/login
#
# "Server URL" en el login debe ser solo el origen de la API, SIN /manager:
#   bien → http://127.0.0.1:8080  o  http://127.0.0.1:3001
#   mal  → http://127.0.0.1:8080/manager  (en :8080 da HTML y "Invalid server"; en :3001 el nginx
#          ahora enruta JSON para /manager/ si Accept es application/json)
