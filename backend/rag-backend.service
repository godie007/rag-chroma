[Unit]
Description=RAG Backend Service
After=network.target

[Service]
User=jetson
WorkingDirectory=/home/jetson/workspace/codla/backend
Environment="PATH=/usr/local/bin:/usr/bin:/bin:/home/jetson/.local/bin"
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 3333
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
