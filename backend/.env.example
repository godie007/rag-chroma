# Obligatorio para embeddings, chat e ingesta
OPENAI_API_KEY=

# Modelos (opcional)
OPENAI_CHAT_MODEL=gpt-4o-mini
# Creatividad del chat RAG (0 = determinista, sube para más variación; RAGAS sigue usando 0 en evaluation.py)
OPENAI_CHAT_TEMPERATURE=0.1
# Máx. tokens de salida del /chat RAG (sube p.ej. a 8192 para respuestas más largas)
OPENAI_CHAT_MAX_OUTPUT_TOKENS=4096
# text-embedding-3-small (rápido/barato, 1536 dims nativas) | text-embedding-3-large (más calidad, 3072 dims nativas)
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# MRL (Matryoshka) solo con text-embedding-3-*. Ej.: 1024 o 256 con large, 512 con small. Vacío = dimensión nativa del modelo.
# Tras cambiar modelo o dimensiones, Chroma exige un índice vacío: POST /ingest/reset y volver a ingerir.
#OPENAI_EMBEDDING_DIMENSIONS=1024

# Azure OpenAI u otro compatible: descomenta y ajusta
# OPENAI_API_BASE=https://tu-recurso.openai.azure.com/openai/deployments/TU_DEPLOYMENT
# Para Azure suele requerirse versión en el cliente; langchain-openai usa la API estándar si el base apunta al proxy correcto.

# Chroma en disco: rutas relativas se resuelven respecto a backend/ (no al CWD de uvicorn).
# Si ves error 1032 "readonly database", evita carpetas sincronizadas (iCloud) o usa p.ej. /tmp/chroma_scanntech
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=internal_knowledge
# Lotes al insertar en Chroma (PDFs enormes)
CHROMA_INGEST_BATCH_SIZE=128
# PDF: PyMuPDF find_tables() en cada página es costoso (normas 600+ pág. como CEC: tiempo/RAM). 0=sin límite (todas las págs).
# Pon p.ej. 400 para indexar con tablas estruct. solo al inicio y acelerar el resto.
# PDF_INGEST_FIND_TABLES_MAX_PAGES=400

# Chunking / recuperación (MMR reduce fragmentos redundantes → suele subir context_precision)
# Tras cambiar CHUNK_SIZE/CHUNK_OVERLAP: POST /ingest/reset y volver a subir documentos
CHUNK_SIZE=1400
CHUNK_OVERLAP=280
# Fusiona trozos < N caracteres con el vecino (títulos sueltos → mismo chunk que el párrafo)
CHUNK_MIN_CHARS=400
# 0 = usar 2×CHUNK_SIZE como tope al fusionar
CHUNK_MERGE_HARD_MAX=0
TOP_K=8
USE_MMR=true
MMR_FETCH_K=60
MMR_LAMBDA=0.75
# Máx. distancia L2 aceptada; por encima no hay recuperación (evita sources irrelevantes en saludos / ruido)
RETRIEVE_MAX_L2_DISTANCE=1.25
# Solo fragmentos con distancia <= (mejor candidato + este margen); orden final de más a menos relevante
RETRIEVE_RELEVANCE_MARGIN=0.12
# Opcional: cortar si salto L2 entre dos vecinos ordenados supera este valor (0 = off)
RETRIEVE_ELBOW_L2_GAP=0.08
# En ingesta: el LLM antepone 1-2 frases a cada trozo (mejora búsqueda; citas con texto original vía metadato)
# ENABLE_CONTEXTUAL_RETRIEVAL=false
# CONTEXTUAL_RETRIEVAL_MODEL=gpt-4o-mini
# Límite de documento en el prompt (caracteres); salida del modelo para el prefijo
# CONTEXTUAL_RETRIEVAL_MAX_DOC_CHARS=50000
# CONTEXTUAL_RETRIEVAL_MAX_OUTPUT_TOKENS=150
# Llamadas concurrentes a OpenAI al contextualizar (no bloquea la ingesta en serie)
# CONTEXTUAL_RETRIEVAL_CONCURRENCY=4
# true = el chat usa una mini-llamada al LLM para decidir recuperación amplia vs concreta (sin regex en código).
# false = siempre recuperación "normal" (útil si quieres evitar esa llamada extra).
LLM_RETRIEVAL_PROFILE=true

# Bucle de clarificación (LangGraph: si la consulta es ambigua, pregunta al usuario; /chat pasa thread_id)
# Por defecto en código: activado. Pon false solo si quieres RAG directo sin ronda de aclaración:
# RAG_CLARIFICATION_ENABLED=false
# RAG_CLARIFICATION_MAX_ROUNDS=3
# true = LLM de expansión semántica antes del primer retrieve (sinónimos / términos normativos)
# RAG_CLARIFY_SEMANTIC_EXPAND=true
#
# Parent–child (hijos en Chroma, padres en disco) + rerank cross-encoder (sentence-transformers).
# Tras activar: POST /ingest/reset e indexar de nuevo. Incompatible con el índice "plano" anterior.
# PARENT_RERANK_ENABLED=false
# RAG_RETRIEVER_K=20
# RAG_RERANKER_TOP_N=6
# RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RETRIEVAL_EXCLUDE_SECTION_TYPES=portada_indice,indice

# CORS (coma-separado). Añade el origen exacto del front (esquema + host + puerto), p. ej. http://localhost:5173
CORS_ORIGINS=http://localhost:4444,http://127.0.0.1:4444,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Tamaño máximo por archivo (bytes). 200 MiB por defecto; sube p.ej. 524288000 para ~500 MiB
MAX_UPLOAD_BYTES=209715200

# --- WhatsApp (Jetson: GOWA Docker :3000 + API Flask :8090) ---
# Sin Flask en el Jetson/VM: usa el bridge de este repo (traduce :8090 → GOWA :3000):
#   uvicorn app.whatsapp_gowa_bridge:app --host 127.0.0.1 --port 8090
#   (o proceso PM2 ``whatsapp-gowa-bridge`` en ecosystem.config.cjs del repo)
#   Env opcionales del bridge: GOWA_UPSTREAM_URL=http://127.0.0.1:3000, GOWA_DEVICE_ID=,
#   WHATSAPP_BRIDGE_API_KEY= (si pones la misma en WHATSAPP_API_KEY del RAG).
# Alineado con /home/jetson/README.md, whatsapp_api.py y whatsapp_receiver.sh
#
# Enviar (misma API :8090 que usa el backend para contestar):
#   curl -X POST http://192.168.1.254:8090/send/text \
#     -H "Content-Type: application/json" \
#     -d '{"phone": "+573135656345", "message": "Hola!"}'
#
# Recibir en el Jetson (manual) — la API expone:
#   GET /messages/recent?limit=50   → mensajes recientes; cada uno trae is_from_me: true/false (el RAG filtra según .env)
#   GET /messages?chat_jid=573218288790@s.whatsapp.net&limit=50   → mensajes de un solo chat (mismo is_from_me)
#   curl "http://192.168.1.254:8090/messages/recent?limit=50"
#   curl "http://192.168.1.254:8090/messages?chat_jid=573218288790@s.whatsapp.net&limit=50"
# Automático en Jetson: whatsapp_receiver.sh (puede hacer POST al webhook del RAG abajo).
#
# Este backend (RAG):
# WHATSAPP_ENABLED=false
# WHATSAPP_API_BASE_URL=http://192.168.1.254:8090
# Polling: recent = GET /messages/recent | chats = GET /chats luego GET /messages por chat_jid
# WHATSAPP_POLL_MODE=recent
# WHATSAPP_POLL_ENABLED=true
# WHATSAPP_POLL_INTERVAL_SEC=4
# WHATSAPP_POLL_LIMIT=50
# WHATSAPP_CHATS_POLL_LIMIT=25
# WHATSAPP_MESSAGES_PER_CHAT_LIMIT=40
# Al arrancar, no contestar el histórico de /messages/recent (usa timestamp de la API + is_from_me):
# WHATSAPP_POLL_SKIP_MESSAGES_BEFORE_START=true
# Holgura si el reloj del Jetson va un poco rezagado (segundos)
# WHATSAPP_POLL_START_SKEW_SEC=90
# Bearer opcional si whatsapp_api.py lo exige:
# WHATSAPP_API_KEY=
# Webhook en ESTE servidor (reenvío desde receiver o Flask): POST /webhooks/whatsapp
# WHATSAPP_WEBHOOK_SECRET=
# WHATSAPP_REPLY_IN_GROUPS=false
# WHATSAPP_POLL_LOG_BODY=false
# Si escribes desde el mismo WhatsApp que está en el Jetson, los mensajes suelen venir is_from_me=true:
# WHATSAPP_PROCESS_FROM_ME=false
# WHATSAPP_FROM_ME_MAX_QUESTION_CHARS=4000
# Allowlist: dígitos sin +, separados por coma. Vacío = cualquiera puede escribir al bot en chats 1:1.
# IMPORTANTE: aquí van los números de quien *envía* mensajes al bot (clientes/probadores), NO el número
# con el que está logueado GOWA. Si pones solo el número de la sesión, los mensajes reales quedarán bloqueados.
# WHATSAPP_ALLOWED_SENDER_NUMBERS=573199999999,5731888888888
